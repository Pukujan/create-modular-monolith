{
  "name": "modular-monolith-starter",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "sync:cli-template": "node additional-modules/scripts/sync-cli-template.mjs",
    "export:architecture-starter": "node additional-modules/scripts/export-architecture-starter.mjs",
    "dev:backend": "npm --prefix backend run dev",
    "dev:frontend": "npm --prefix frontend run dev",
    "lint:boundaries": "npm --prefix backend run lint:boundaries",
    "lint:layers": "npm --prefix backend run lint:layers",
    "lint:api-docs": "node additional-modules/scripts/check-api-docs.mjs",
    "lint:contracts": "node additional-modules/scripts/lint-contracts.mjs",
    "lint:repo-artifacts": "node additional-modules/scripts/lint-repo-artifacts.mjs",
    "lint:deploy": "node additional-modules/scripts/lint-deploy.mjs",
    "lint:architecture": "npm --prefix backend run lint:architecture",
    "test": "npm --prefix backend test && npm --prefix frontend test",
    "test:evals": "npm --prefix backend run test:evals",
    "test:ci": "npm run lint:contracts && npm run lint:repo-artifacts && npm run lint:deploy && npm run lint:architecture && npm test && npm run test:evals",
    "new:module": "node additional-modules/scripts/new-module.mjs",
    "condense-prompts": "node additional-modules/scripts/condense-prompts.mjs",
    "condense-file-structure": "node additional-modules/scripts/condense-file-structure.mjs",
    "condense-contracts": "node additional-modules/scripts/condense-contracts.mjs",
    "condense:all": "node additional-modules/scripts/condense-all.mjs",
    "plan:finalize": "node additional-modules/scripts/plan-finalize.mjs",
    "plan:gate": "node additional-modules/scripts/plan-gate.mjs",
    "dev-log:pre-push": "node additional-modules/scripts/write-pre-push-dev-log.mjs",
    "dev-log:verify": "node additional-modules/scripts/verify-dev-log.mjs",
    "dev-log:sync-head": "node additional-modules/scripts/sync-dev-log-head.mjs",
    "dev-log:install-hook": "node additional-modules/scripts/install-dev-log-hook.mjs",
    "import:file-exchange": "node additional-modules/scripts/import-to-file-exchange.mjs"
  }
}
