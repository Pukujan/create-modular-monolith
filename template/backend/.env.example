# Backend — copy to backend/.env
PORT=3001

# OpenRouter — https://openrouter.ai/keys
# Vision OCR model is hardcoded: qwen/qwen3-vl-8b-instruct (vision-ocr.adapter.js)
OPENROUTER_API_KEY=your_openrouter_api_key_here
MODEL_TEXT_REASONING=google/gemini-2.0-flash-001
OPENROUTER_SITE_URL=http://localhost:5173
OPENROUTER_APP_NAME=Case Filing AI
# OCR_MAX_PAGES=8

# Extractor agent — light profile extraction for rule lookup; heavy task reserved for future
MODEL_EXTRACT_LIGHT=google/gemini-2.0-flash-001
# MODEL_EXTRACT_HEAVY=google/gemini-2.0-flash-001
EXTRACT_MAX_INPUT_CHARS=24000

# External artifact root (optional): copy local-artifacts.example.json → local-artifacts.json at repo root
# ARTIFACT_ROOT=  # or set artifactRoot in local-artifacts.json
# FILE_EXCHANGE_ROOT=

# Per-path overrides (take precedence over local-artifacts.json)
CASE_FILING_BATCH_DIR=
CASE_FILING_MAX_UPLOAD_MB=25

# Model condenser (optional output override)
MODEL_CONDENSER_OUTPUT_DIR=
MODEL_CONDENSER_OUTPUT_FILE=consolidated-models.json

# Golden dataset eval (rule-authority v002 recommended for synthetic case 001)
GOLDEN_DATASET_DIR=
GOLDEN_CASE_ID=case_001_rule_authority_v002
RULE_FIXTURES_CASE_ID=
RULE_SET_VERSION=

# Master prompt: v001 injects rankedRules; auto-selected when GOLDEN_CASE_ID is rule_authority v002
MASTER_PROMPT_VERSION=

# Eval report bundles copied to repo root (default: eval-bundles/)
# Case bundle: eval-bundles/{name}/golden/ + runs/{batchId}/
EVAL_BUNDLE_ROOT_DIR=

# Full case export (uploads, outputs, evals, rules, snapshots)
CASE_EXPORT_ROOT_DIR=

MASTER_PROMPT_JSON_RETRY=true
MASTER_PROMPT_OMIT_AUDIT_NOTES=true
MASTER_PROMPT_MAX_AUDIT_NOTES=20
MASTER_PROMPT_MAX_DOC_CHARS=120000
# compact or v2: compact prompt + structured snapshot merge
# OPENROUTER_JSON_OBJECT_MODE=true
OPENROUTER_JSON_OBJECT_MODE=false

# Document persistence (contract: documentPersistence v001)
# Vault + ai-ops agent runs share one Neon Postgres database (required for local dev).

# Required — Neon Postgres (ai-ops + document vault)
DATABASE_URL=postgresql://USER:PASS@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
QUEUE_DISABLED=true

# Integration tests only — do not set for normal dev
# ALLOW_SQLITE=true

# Async jobs (contract: asyncJobQueue v001) — BullMQ requires Redis (both free OSS)
# REDIS_URL=redis://127.0.0.1:6379
# QUEUE_DISABLED=true              # optional: inline jobs in dev without Redis

# Optional Google Custom Search (source-discovery-agent fallback uses seed data when unset)
# GOOGLE_SEARCH_API_KEY=
# GOOGLE_SEARCH_CX=
